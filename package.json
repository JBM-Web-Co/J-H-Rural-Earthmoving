{
    "name": "landing-page-template",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "react-router dev --host",
        "vercel-dev": "vercel dev",
        "build": "npm run typecheck && npm run buildEmails && react-router build",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p api/tsconfig.json",
        "style": "npx prettier --write '**/*.{js,ts,tsx,json,scss}'",
        "buildEmails": "tsx scripts/buildEmails.ts"
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "es5"
    },
    "dependencies": {
        "@react-email/components": "^1.0.12",
        "@react-router/node": "^8.0.1",
        "@vercel/analytics": "^2.0.1",
        "animejs": "^4.5.0",
        "isbot": "^5",
        "lucide-react": "^1.21.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router": "^8.0.1",
        "resend": "^6.14.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@react-email/preview-server": "^5.2.11",
        "@react-router/dev": "^8.0.1",
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vercel/node": "^5.8.21",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "sass": "^1.101.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0"
    }
}
